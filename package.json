{
  "name": "@lovelace_lol/polymer",
  "version": "0.0.0",
  "description": "Pure ClojureScript character agencies for Character Loom.",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "shadow-cljs.edn",
    "README.md"
  ],
  "scripts": {
    "build": "rm -f dist/index.js dist/index.cjs dist/index.mjs && shadow-cljs release npm",
    "test": "shadow-cljs compile test && node dist/test.cjs",
    "check:install-surface": "node scripts/check-git-install-surface.mjs",
    "check:architecture": "node scripts/check-agency-architecture.mjs",
    "check:dist": "node scripts/check-built-dist.mjs",
    "clean": "rm -rf .shadow-cljs dist/test.js dist/test.cjs"
  },
  "dependencies": {
    "@lovelace_lol/embody": "github:meekmachine/embody#43caf9c031a17757612425e4151c43558a7773aa"
  },
  "devDependencies": {
    "shadow-cljs": "^2.28.23"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meekmachine/Polymer.git"
  },
  "packageManager": "pnpm@10.25.0"
}
