{
  "name": "@lovelace_lol/polymer",
  "version": "0.0.0",
  "description": "Pure ClojureScript character agencies for Character Loom.",
  "license": "UNLICENSED",
  "private": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "shadow-cljs.edn",
    "README.md"
  ],
  "scripts": {
    "build": "shadow-cljs release npm worker",
    "test": "shadow-cljs compile test && node dist/test.js && shadow-cljs release worker && node test/worker_smoke.cjs",
    "check:install-surface": "node scripts/check-git-install-surface.mjs",
    "check:dist": "pnpm build && git diff --exit-code -- dist",
    "clean": "rm -rf .shadow-cljs dist/test.js",
    "prepublishOnly": "pnpm test && pnpm build && git diff --exit-code -- dist"
  },
  "dependencies": {
    "@lovelace_lol/loom3": "git+https://github.com/meekmachine/embody.git#1b4da9bfa70e82796f88e768e877a0bb3f6894c0"
  },
